# ===== LLM & Embeddings =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# ===== Vector Stores =====
PINECONE_API_KEY=
WEAVIATE_URL=
WEAVIATE_API_KEY=

# ===== Object Storage =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AZURE_STORAGE_CONNECTION_STRING=
GCP_SERVICE_ACCOUNT_FILE=./gcp-service-account.json

# ===== Backend =====
GLIH_BACKEND_PORT=9001
GLIH_CONFIG=./config/glih.toml
GLIH_BACKEND_URL=http://localhost:9001

# ===== Frontend =====
NEXT_PUBLIC_BACKEND_URL=http://localhost:9001

# ===== Database =====
POSTGRES_USER=glih
POSTGRES_PASSWORD=changeme
POSTGRES_DB=glih
POSTGRES_HOST=localhost
POSTGRES_PORT=9006

# ===== Redis =====
REDIS_URL=redis://localhost:9007

# ===== MCP Connectors (Fleet & IoT) =====
# GPS-Trace - Truck tracking (gps-trace.com)
GPS_TRACE_API_TOKEN=

# OpenWeatherMap - Weather forecasts (openweathermap.org/api)
OPENWEATHERMAP_API_KEY=

# Lineage IoT - Temperature sensors, door status
IOT_MODE=demo
IOT_MQTT_BROKER=
IOT_MQTT_PORT=1883
IOT_MQTT_USERNAME=
IOT_MQTT_PASSWORD=
IOT_API_ENDPOINT=
IOT_API_KEY=

# Traffic API - Route optimization (google/here/mapbox)
TRAFFIC_PROVIDER=demo
TRAFFIC_API_KEY=

# ===== Auth =====
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
# Dispatcher admin password — required for dispatcher panel login (no default allowed)
DISPATCHER_ADMIN_PASSWORD=
# Allowed CORS origins — comma-separated list of frontend URLs
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ===== Observability =====
# Sentry — error tracking (sentry.io — free tier)
SENTRY_DSN=
GLIH_ENV=development

# Langfuse — LLM observability: traces every prompt/response, token cost per user
# Get keys from cloud.langfuse.com — free tier available
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Rate Limiting =====
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_AGENTS=20/minute
RATE_LIMIT_INGEST=10/minute

# ===== Cloud Deployment =====
# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# GCP
GCP_PROJECT=
GCP_REGION=us-central1

# Azure
AZURE_ACR_NAME=
